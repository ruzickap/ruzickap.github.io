### kubecost

To see the price details of the EKS cluster we can use [Kubecost](https://aws.amazon.com/blogs/containers/aws-and-kubecost-collaborate-to-deliver-cost-monitoring-for-eks-customers/).

Install `kubecost`
[helm chart](https://github.com/kubecost/cost-analyzer-helm-chart/tree/v1.99.0/cost-analyzer)
and modify the
[default values](https://github.com/kubecost/cost-analyzer-helm-chart/blob/v1.99.0/cost-analyzer/values.yaml).

```bash
# renovate: datasource=helm depName=kubecost registryUrl=https://kubecost.github.io/cost-analyzer
KUBECOST_HELM_CHART_VERSION="1.99.0"

helm repo add --force-update kubecost https://kubecost.github.io/cost-analyzer/
helm upgrade --install --version "${KUBECOST_HELM_CHART_VERSION}" --namespace kubecost --create-namespace --values - kubecost kubecost/cost-analyzer << EOF
global:
  prometheus:
    enabled: true
  grafana:
    enabled: false
    # proxy: false
kubecostFrontend:
  image: public.ecr.aws/kubecost/frontend
kubecostModel:
  image: public.ecr.aws/kubecost/cost-model
  warmCache: true
podSecurityPolicy:
  enabled: false
persistentVolume:
  size: 1Gi
  dbSize: 1Gi
ingress:
  enabled: true
  className: nginx
  annotations:
    forecastle.stakater.com/expose: "true"
    forecastle.stakater.com/icon: https://avatars.githubusercontent.com/u/45108136?s=200&v=4
    forecastle.stakater.com/appName: Kubecost
    nginx.ingress.kubernetes.io/auth-url: https://oauth2-proxy.${CLUSTER_FQDN}/oauth2/auth
    nginx.ingress.kubernetes.io/auth-signin: https://oauth2-proxy.${CLUSTER_FQDN}/oauth2/start?rd=\$scheme://\$host\$request_uri
  paths: ["/"]
  hosts:
    - cost-analyzer.${CLUSTER_FQDN}
  tls:
    - hosts:
        - cost-analyzer.${CLUSTER_FQDN}
prometheus:
  server:
    image:
      repository: public.ecr.aws/kubecost/prometheus
      tag: v2.35.0
    persistentVolume:
      size: 1Gi
  # configmapReload:
  #   prometheus:
  #     ## If false, the configmap-reload container will not be deployed
  #     ##
  #     enabled: false

  #     ## configmap-reload container name
  #     ##
  #     name: configmap-reload
  #     ## configmap-reload container image
  #     ##
  #     image:
  #       repository: public.ecr.aws/bitnami/configmap-reload
  #       tag: 0.7.1
  #       pullPolicy: IfNotPresent
  #     ## Additional configmap-reload container arguments
  #     ##
  #     extraArgs: {}
  #     ## Additional configmap-reload volume directories
  #     ##
  #     extraVolumeDirs: []
  #     ## Additional configmap-reload mounts
  #     ##
  #     extraConfigmapMounts: []
  #       # - name: prometheus-alerts
  #       #   mountPath: /etc/alerts.d
  #       #   subPath: ""
  #       #   configMap: prometheus-alerts
  #       #   readOnly: true
  #     ## configmap-reload resource requests and limits
  #     ## Ref: http://kubernetes.io/docs/user-guide/compute-resources/
  #     ##
  #     resources: {}

  nodeExporter:
    enabled: false
reporting:
  productAnalytics: false
EOF
```







